    "Mass_3D":
    {
        "bins": [
            {
                "name": "Reco_Y_mass",
                "label": "Reco level Y mass (GeV)",
                #"n_or_arr": 20,
                #"lo": 0,
                #"hi": 300
                "n_or_arr": 20,
                "lo": 20,
                "hi": 500
            },
            {
                "name": "Reco_Yprime_mass",
                "label": "Reco level Yprime mass (GeV)",
                #"n_or_arr": 40,
                #"lo": 0,
                #"hi": 800
                "n_or_arr": 20,
                "lo": 30,
                "hi": 2000
            },
            {
                "name": "Reco_X_mass",
                "label": "Reco level X mass (GeV)",
                #"n_or_arr": 60,
                #"lo": 0,
                #"hi": 5000
                "n_or_arr": 40,
                "lo": 500,
                "hi": 7000
            }
        ],
        "fill": {
            "Reco_Y_mass": [
                "Reco_Y_mass",
            ],
            "Reco_Yprime_mass": [
                "Reco_Yprime_mass",
            ],
            "Reco_X_mass": [
                "Reco_X_mass",
            ],
        },
        "step_requirement": "cut:Lumi"
    },
