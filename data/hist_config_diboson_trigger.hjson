    "HT":
    {
        "bins": [
            {
                "name": "HT",
                "label": "HT (GeV)",
                "n_or_arr": 70,
                "lo": 0,
                "hi": 7000
            }
        ],
        "cats": [
            {
                "name": "muon_triggers",
                "label": "muon_triggers"
            },
            {
                "name": "jet_triggers",
                "label": "jet_triggers"
            }
        ],
        "fill": {
            "HT": [
                "HT"
            ],
            "muon_triggers": {
                "m_pass": [
                    "muon_triggers"
                ],
                "m_fail": [
                    "muon_triggers",
                    {"function": "not"}
                ]
            },
            "jet_triggers": {
                "j_pass": [
                    "jet_triggers"
                ],
                "j_fail": [
                    "jet_triggers",
                    {"function": "not"}
                ]
            }
        },
        "step_requirement": "column:HT"
    },
}
