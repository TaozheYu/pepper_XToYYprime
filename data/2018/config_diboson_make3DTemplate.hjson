    "btag_method": "fixedwp",
    "btag_measure_type": "mujets",
    "num_atleast_btagged": 1,

    "btag_sf": [
        [
            "$DATADIR/btag/btagging.json",
            "$DATADIR/btag/btag_efficiencies.root"
