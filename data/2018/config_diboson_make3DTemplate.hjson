    ],

    ##################################################
    # other uncs, options
    ##################################################

    "split_pdf_uncs": true,
    "normalize_pdf_uncs": true,
    "pdf_types": {
        "91400": "Hessian",
        "306000": "Hessian",
        "325300": "Hessian",
        "325500": "Hessian",
        "320900" : "MC_Gaussian"
    },

    "top_pt_reweighting": {
        "method": "theory",
        "scale": 1,
        "a": 0.103,
        "b": -0.0118,
        "c": -0.000134,
        "d": 0.973,
        "sys_only": true
    },

